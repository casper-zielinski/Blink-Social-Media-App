rules_version = '2';

// Firestore-Sicherheitsregeln für Blink.
// Jeder angemeldete Nutzer darf lesen und schreiben – passend für dieses
// Studienprojekt. Ohne diese Regeln liefert Firestore PERMISSION_DENIED und
// weder Posts noch Kommentare lassen sich laden oder speichern.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
